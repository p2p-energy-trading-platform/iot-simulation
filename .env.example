# System Environment
NODE_ENV=development
LOG_LEVEL=info

# MQTT Broker Connection Configuration
MQTT_PROTOCOL=mqtt
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=gridx_iot_simulator_host
MQTT_KEEPALIVE=60

# Simulation Core Mechanics
SIMULATOR_TICK_MS=5000 # in milliseconds (5 seconds)
HEARTBEAT_INTERVAL_MS=60000 # in milliseconds (1 minute)

# Weather Engine Integration
WEATHER_SYNC_INTERVAL_MS=900000 # Fetch Open-Meteo data every 15 minutes
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast